{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/(.*)$",
      "has": [
        {
          "type": "host",
          "value": "valiantdoor.com"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "https://www.valiantdoor.com/$1"
      }
    },
    {
      "src": "^/(.+)/$",
      "status": 308,
      "headers": {
        "Location": "/$1"
      }
    },
    {
      "src": "^/api/(.*)$",
      "dest": "server/server.js"
    },
    {
      "src": "^/services/emergency/?$",
      "status": 308,
      "headers": {
        "Location": "/emergency-garage-door-repair"
      }
    },
    {
      "src": "^/services/installations/?$",
      "status": 308,
      "headers": {
        "Location": "/garage-door-installation"
      }
    },
    {
      "src": "^/$",
      "dest": "public/index.html"
    },
    {
      "src": "^/services$",
      "dest": "public/services/index.html"
    },
    {
      "src": "^/mission$",
      "dest": "public/mission/index.html"
    },
    {
      "src": "^/mastertech$",
      "dest": "public/mastertech/index.html"
    },
    {
      "src": "^/quote$",
      "dest": "public/quote/index.html"
    },
    {
      "src": "^/garage-door-installation$",
      "dest": "public/garage-door-installation/index.html"
    },
    {
      "src": "^/gallery$",
      "dest": "public/gallery/index.html"
    },
    {
      "src": "^/thank-you$",
      "dest": "public/thank-you/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "public/$1"
    }
  ],
  "trailingSlash": false
}
